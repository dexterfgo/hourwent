# Setup: cp .env.example .env  then  chmod 600 .env
# (chmod 600 makes the file readable only by you)

# Amazon account credentials (used for first-time login)
ALEXA_EMAIL=your_amazon_email@example.com
ALEXA_PASSWORD=your_amazon_password

# After first login via the proxy (http://localhost:3131), copy the printed
# cookie here. Subsequent runs will skip the browser login entirely.
# Supports MFA — just complete it in the browser during the first run.
ALEXA_COOKIE=

# Exact name of the Echo speaker as shown in the Alexa app
ALEXA_SPEAKER_NAME=Living Room Echo

# Amazon region — change for your country:
#   amazon.com       + pitangui.amazon.com   (US, default)
#   amazon.com.au    + pitangui.amazon.com   (Australia)
#   amazon.co.uk     + layla.amazon.co.uk    (UK)
#   amazon.de        + layla.amazon.de       (Germany)
AMAZON_PAGE=amazon.com.au
ALEXA_SERVICE_HOST=pitangui.amazon.com

# ── Time range (24-hour, both inclusive) ──────────────────────────────────────
# START_HOUR : first hour to announce (0–23)
# END_HOUR   : last  hour to announce (0–23); 0 = midnight
# Supports wrap-around, e.g. START_HOUR=22 END_HOUR=1 covers 10 PM, 11 PM, midnight, 1 AM
START_HOUR=6
END_HOUR=0
