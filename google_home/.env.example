# Friendly name of your Google Home / Nest speaker (must match the Google Home app)
GOOGLE_SPEAKER_NAME=Living Room speaker

# Volume for announcements (0.0 = silent, 1.0 = maximum)
TTS_VOLUME=0.8

# BCP-47 language tag for TTS
TTS_LANGUAGE=en-us

# ── Time range (24-hour, both inclusive) ──────────────────────────────────────
# START_HOUR : first hour to announce (0–23)
# END_HOUR   : last  hour to announce (0–23); 0 = midnight
# Supports wrap-around, e.g. START_HOUR=22 END_HOUR=1 covers 10 PM, 11 PM, midnight, 1 AM
START_HOUR=6
END_HOUR=0
